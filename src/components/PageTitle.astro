---
const { entry } = Astro.locals.starlightRoute;
const { title, date, lastUpdated, template } = entry.data;

function formatDate(d: Date) {
  return d.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' });
}

const updatedDate = lastUpdated instanceof Date ? lastUpdated : undefined;
const isSplash = template === 'splash';

// Reading time (~200 words/min for technical content)
const rawBody: string = (entry as any).body ?? '';
const wordCount = rawBody.trim().split(/\s+/).filter((w: string) => w.length > 0).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

// Breadcrumb from entry id/slug
const rawId: string = ((entry as any).id ?? (entry as any).slug ?? '').replace(/\.mdx?$/, '');
const segments = rawId.split('/').filter(Boolean);

const SECTION_LABELS: Record<string, string> = {
  terraform: 'Terraform',
};

const crumbs = segments.length > 1
  ? segments.slice(0, -1).map((s: string) => SECTION_LABELS[s] ?? (s.charAt(0).toUpperCase() + s.slice(1)))
  : [];
---

{!isSplash && crumbs.length > 0 && (
  <nav class="breadcrumb" aria-label="Fil d'Ariane">
    <a href="/">Accueil</a>
    {crumbs.map((label: string) => (
      <>
        <span class="sep" aria-hidden="true">›</span>
        <span>{label}</span>
      </>
    ))}
    <span class="sep" aria-hidden="true">›</span>
    <span class="current" aria-current="page">{title}</span>
  </nav>
)}

<h1 id="_top">{title}</h1>

{!isSplash && (
  <div class="article-meta">
    <span class="meta-author">Loïc Rossignol</span>
    {date && (
      <time class="meta-item" datetime={date.toISOString()}>
        Publié le {formatDate(date)}
      </time>
    )}
    {updatedDate && (
      <time class="meta-item" datetime={updatedDate.toISOString()}>
        Mis à jour le {formatDate(updatedDate)}
      </time>
    )}
    <span class="meta-item">{readingTime} min de lecture</span>
  </div>
)}

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.2rem;
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-4);
    margin-bottom: 0.75rem;
  }
  .breadcrumb a {
    color: var(--sl-color-gray-4);
    text-decoration: none;
    transition: color 0.15s;
  }
  .breadcrumb a:hover {
    color: var(--sl-color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .breadcrumb .sep {
    color: var(--sl-color-gray-5);
    font-size: 0.7rem;
    margin: 0 0.1rem;
  }
  .breadcrumb .current {
    color: var(--sl-color-gray-3);
    font-weight: 500;
    max-width: 35ch;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  h1 {
    margin-top: 0.25rem;
    font-size: var(--sl-text-h1);
    line-height: var(--sl-line-height-headings);
    font-weight: 600;
    color: var(--sl-color-text);
  }
  .article-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.25rem 0;
    margin-top: 0.6rem;
    margin-bottom: 1.75rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--sl-color-hairline-light);
    font-size: var(--sl-text-sm);
  }
  .meta-author {
    font-weight: 500;
    color: var(--sl-color-gray-3);
  }
  .meta-item {
    color: var(--sl-color-gray-4);
  }
  .meta-item::before {
    content: '·';
    margin: 0 0.5rem;
    color: var(--sl-color-gray-5);
  }
</style>
